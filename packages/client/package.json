{
  "name": "@jpyc-x402/client",
  "version": "0.1.0",
  "description": "TypeScript client SDK for x402 on JPYC. Sign EIP-3009 authorizations and call any facilitator over HTTP.",
  "license": "MIT",
  "author": "Mameta29",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mameta29/jpyc-x402-facilitator.git",
    "directory": "packages/client"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist .turbo",
    "lint": "echo 'lint via prettier at root'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@jpyc-x402/shared": "workspace:*",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}

{
  "name": "jpyc-x402-facilitator-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "x402 facilitator and SDKs for JPYC (Japanese Yen Stablecoin)",
  "license": "MIT",
  "author": "Mameta29",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mameta29/jpyc-x402-facilitator.git"
  },
  "homepage": "https://github.com/Mameta29/jpyc-x402-facilitator#readme",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@10.7.1",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=10.0.0"
  }
}
